{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "env.d.ts",
    "src/**/*",
    "src/**/*.vue"
  ],
  "exclude": [
    "src/**/__tests__/*"
  ],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "baseUrl": "./",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@views/*": [
        "src/views/*"
      ],
      "@stores/*": [
        "src/stores/*"
      ],
      "@data/*": [
        "src/data/*"
      ],
      "@composables/*": [
        "src/composables/*"
      ],
      "@components/*": [
        "src/components/*"
      ],
      "@layouts/*": [
        "src/layouts/*"
      ],
      "@router/*": [
        "src/router/*"
      ],
      "@common/*": [
        "src/components/common/*"
      ],
      "@services/*": [
        "src/services/*"
      ],
      "@icon/*": [
        "src/assets/icon/*"
      ]
    }
  }
}